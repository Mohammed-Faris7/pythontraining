#magic number using function
num=int(input("enter a number: "))
def magic_number(num):
    while num>9:
        sum=0
        while num>0:
            d=num%10
            sum=sum+d
            num=num//10
        num=sum
    if num==1:
        return True
    else:
        return False
print(magic_number(num))
        
    
