#strong number using function
num=int(input("enter a number: "))
temp=num
def strong_number(num,temp,sum=0):
    while num>0:
        d=num%10
        fact=1
        for i in range(1,d+1):
            fact*=i
        sum=sum+fact
        num=num//10
    if sum==temp:
        return True
    else:
        return False
print(strong_number(num,temp))
        
